<Window x:Class="WebDavSync.Portable.Ui.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.modernwpf.com/2019"
        ui:WindowHelper.UseModernWindowStyle="True"
        Title="WebDavSync"
        Height="660" Width="560"
        MinHeight="580" MinWidth="500"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResize"
        SnapsToDevicePixels="True">

    <ui:ThemeManager.RequestedTheme>Light</ui:ThemeManager.RequestedTheme>

    <DockPanel>

        <!-- ══ BOTTOM BAR ══ -->
        <Border DockPanel.Dock="Bottom"
                BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
                BorderThickness="0,1,0,0"
                Padding="16,10">
            <DockPanel>
                <StackPanel DockPanel.Dock="Left" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock FontSize="11" FontWeight="SemiBold"
                               Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}">WEBDAVSYNC</TextBlock>
                    <TextBlock x:Name="VersionTextBlock" FontSize="11"
                               Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"
                               Margin="5,0,0,0"/>
                </StackPanel>
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal"
                            HorizontalAlignment="Right" VerticalAlignment="Center">
                    <Button x:Name="CheckUpdatesButton" Margin="0,0,8,0"
                            Click="CheckUpdatesButton_Click">Check for Updates</Button>
                    <Button x:Name="SaveButton"
                            Margin="0,0,8,0" Click="SaveButton_Click">Save</Button>
                    <Button x:Name="CloseButton"
                            Click="CloseButton_Click">Close</Button>
                </StackPanel>
                <Border/>
            </DockPanel>
        </Border>

        <!-- ══ CONTENT ══ -->
        <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="16,12,16,8">
            <StackPanel>

                <!-- ── LOCAL FOLDER ── -->
                <TextBlock Text="Local Folder" FontSize="13" FontWeight="SemiBold" Margin="0,0,0,6"/>
                <ui:SimpleStackPanel Spacing="10" Margin="0,0,0,20">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0" x:Name="WatchFolderTextBox"
                                 ui:ControlHelper.PlaceholderText="e.g. C:\backups"/>
                        <Button Grid.Column="1" Margin="8,0,0,0"
                                Click="BrowseLocalFolder_Click">Browse…</Button>
                    </Grid>
                </ui:SimpleStackPanel>

                <!-- ── SERVER ── -->
                <TextBlock Text="Server" FontSize="13" FontWeight="SemiBold" Margin="0,0,0,6"/>
                <ui:SimpleStackPanel Spacing="10" Margin="0,0,0,20">

                    <TextBox x:Name="WebDavUrlTextBox"
                             ui:ControlHelper.Header="URL"
                             ui:ControlHelper.PlaceholderText="https://dav.example.com/remote.php/dav/files/user/"/>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="16"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0" x:Name="UsernameTextBox"
                                 ui:ControlHelper.Header="Username"
                                 ui:ControlHelper.PlaceholderText="username"/>
                        <PasswordBox Grid.Column="2" x:Name="PasswordTextBox"
                                     ui:ControlHelper.Header="Password"
                                     ui:ControlHelper.PlaceholderText="password"/>
                    </Grid>

                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0" x:Name="RemoteFolderTextBox"
                                 ui:ControlHelper.Header="Remote Folder"
                                 ui:ControlHelper.PlaceholderText="/backups"/>
                        <Button Grid.Column="1" Margin="8,0,0,0" VerticalAlignment="Bottom"
                                Click="BrowseRemoteFolder_Click">Browse…</Button>
                    </Grid>

                    <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                        <Button x:Name="ConnectButton" Click="ConnectButton_Click">Test Connection</Button>
                        <Ellipse x:Name="ConnectionStatusEllipse"
                                 Width="8" Height="8" Fill="#CC3333"
                                 VerticalAlignment="Center" Margin="12,0,6,0"/>
                        <TextBlock x:Name="ConnectionStatusText"
                                   Text="Not connected" FontSize="12"
                                   Foreground="#CC3333" VerticalAlignment="Center"/>
                    </StackPanel>

                </ui:SimpleStackPanel>

                <!-- ── OPTIONS ── -->
                <TextBlock Text="Options" FontSize="13" FontWeight="SemiBold" Margin="0,0,0,6"/>
                <ui:SimpleStackPanel Spacing="8" Margin="0,0,0,20">
                    <CheckBox x:Name="StartWithWindowsCheckBox" Content="Start with Windows"/>
                    <CheckBox x:Name="SyncRemoteChangesCheckBox" Content="Sync remote changes"/>
                </ui:SimpleStackPanel>

                <!-- ── RECENT ACTIVITY ── -->
                <Button Click="ActivityHeader_Click" Margin="0,0,0,6"
                        HorizontalAlignment="Left">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Recent Activity" FontSize="13" FontWeight="SemiBold"/>
                        <TextBlock x:Name="ActivityChevron" Text="&#xE70D;"
                                   FontFamily="Segoe MDL2 Assets" FontSize="10"
                                   VerticalAlignment="Center" Margin="6,0,0,2"
                                   Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>
                    </StackPanel>
                </Button>
                <Border x:Name="ActivityPanel" Visibility="Collapsed" Margin="0,0,0,4" Height="120">
                    <TextBox x:Name="ActivityTextBox"
                             IsReadOnly="True" TextWrapping="Wrap"
                             AcceptsReturn="True" VerticalScrollBarVisibility="Auto"
                             FontFamily="Cascadia Mono, Consolas" FontSize="11"/>
                </Border>

            </StackPanel>
        </ScrollViewer>

    </DockPanel>
</Window>
